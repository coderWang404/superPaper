{
  "databaseUrl": "postgres://postgres:postgres@postgres/write_latex_dev",
  "persistor": {
    "s3": {
      "endpoint": "http://s3:8080",
      "pathStyle": "true"
    },
    "gcs": {
      "unsignedUrls": "true",
      "endpoint": {
        "apiEndpoint": "http://fake-gcs:9090",
        "projectId": "fake"
      }
    }
  },
  "blobStore": {
    "globalBucket": "superpaper-development-blobs",
    "projectBucket": "superpaper-development-project-blobs"
  },
  "chunkStore": {
    "bucket": "superpaper-development-chunks"
  },
  "zipStore": {
    "bucket": "superpaper-development-zips"
  },
  "backupStore": {
    "chunksBucket": "superpaper-development-history-chunks",
    "deksBucket": "superpaper-development-history-deks",
    "globalBlobsBucket": "superpaper-development-history-global-blobs",
    "projectBlobsBucket": "superpaper-development-history-project-blobs"
  },
  "backupPersistor": {
    "keyEncryptionKeys": "[{\"key\":\"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=\",\"salt\":\"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=\"}]",
    "s3SSEC": {
      "ca": "[\"/certs/public.crt\"]"
    }
  },
  "useDeleteObjects": "false",
  "mongo": {
    "uri": "mongodb://mongo:27017/sharelatex"
  },
  "basicHttpAuth": {
    "password": "password"
  },
  "jwtAuth": {
    "key": "secureKey",
    "algorithm": "HS256"
  }
}
